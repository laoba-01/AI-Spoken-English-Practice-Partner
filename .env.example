# 阿里云智能语音服务 AppKey
ALIYUN_ASR_APPKEY=your_asr_appkey
ALIYUN_TTS_APPKEY=your_tts_appkey

# 阿里云 AccessKey（请填写你的 AccessKey ID 和 Secret）
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 阿里云 NLS 服务地址（可选，默认使用公网地址）
# ALIYUN_NLS_URL=

# 豆包大模型 API（火山引擎方舟平台）
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
